<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.DoodleBoard" parent="Theme.Material3.Light.NoActionBar">
        <!-- 主色调 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/surface</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/primary</item>

        <!-- 强调色 -->
        <item name="colorAccent">@color/accent</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/surface</item>

        <!-- 背景 -->
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>

        <!-- 状态栏 -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>

        <!-- 边缘贴合 -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>

        <!-- 按钮样式 -->
        <item name="materialButtonStyle">@style/Widget.Material3.Button</item>
        <item name="borderlessButtonStyle">@style/Widget.Material3.Button.TextButton</item>
    </style>

    <!-- 圆角按钮样式 -->
    <style name="RoundedButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/corner_md</item>
    </style>
</resources>
